# HadoopScope — Template .env
#
# Copia questo file come config/.env e compila i valori reali.
# Il file config/.env NON viene mai committato (e' in .gitignore).
#
# Usage: il file .env viene caricato automaticamente da config.py
#        se si trova nella stessa directory del config file YAML.
#
# Alternativa: esporta le variabili nel shell:
#   export AMBARI_PASS=mypassword
#   export AMBARI_USER=admin

# === HDP (Ambari) ===
AMBARI_USER=admin
AMBARI_PASS=changeme

# === CDP (Cloudera Manager) ===
CM_USER=admin
CM_PASS=changeme

# === Email alerts ===
SMTP_USER=
SMTP_PASS=

# === Webhook ===
WEBHOOK_SECRET=

# === Kerberos ===
# KEYTAB_PATH=/etc/security/keytabs/monitor.keytab

# === Secrets via file (Docker/k8s) ===
# In config YAML usa: ambari_pass: "${file:/run/secrets/ambari_pass}"
# Il file deve contenere il secret senza newline finali.

# === Secrets via comando (Vault, pass, AWS SM, Azure KV) ===
# In config YAML usa:
#   ambari_pass: "${cmd:vault kv get -field=password secret/hadoop/ambari}"
#   ambari_pass: "${cmd:pass show hadoop/ambari}"
#   ambari_pass: "${cmd:aws secretsmanager get-secret-value --secret-id ambari --query SecretString --output text}"
#   ambari_pass: "${cmd:az keyvault secret show --vault-name myVault --name ambariPass --query value -o tsv}"
