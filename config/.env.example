# HadoopScope — Template .env
# =============================================================================
# Copia questo file come config/.env e compila i valori reali.
# Il file config/.env NON viene mai committato (vedi .gitignore).
#
# Il file .env viene caricato automaticamente da config.py se si trova nella
# stessa directory del config YAML.
#
# Alternativa: esporta le variabili nel shell prima di eseguire hadoopscope:
#   export AMBARI_PASS=mypassword && python3 hadoopscope.py ...
# =============================================================================

# === HDP — Ambari ===
AMBARI_USER=admin
AMBARI_PASS=changeme

# === CDP — Cloudera Manager ===
CM_USER=admin
CM_PASS=changeme

# === Hive ===
HIVE_USER=svcaccount
# HIVE_PASS=changeme      # solo per LDAP/PAM auth

# === HiveServer2 SSL (truststore password per la JDBC URL) ===
# La password del truststore finisce nella JDBC URL eseguita sull'EDGE NODE.
# Non è il truststore locale — è il file .jks presente sul nodo edge.
HS2_TRUSTSTORE_PASS=changeme

# === Kerberos per WebHDFS (kinit sulla macchina LOCALE che esegue HadoopScope) ===
# Usato da: checks/webhdfs.py — curl --negotiate verso WebHDFS/JMX
# Il keytab deve essere presente sulla macchina LOCALE.
# KEYTAB_PATH=/etc/security/keytabs/monitor.keytab
# KRB_PRINCIPAL=monitor@CORP.COM

# === Kerberos client per Hive/beeline (kinit sul NODO EDGE via Ansible) ===
# Non è una variabile letta direttamente — il path e il principal vanno
# configurati sotto hive.kerberos nel YAML. Puoi usare ${file:...} o ${cmd:...}
# se il keytab path è dinamico. Esempio nel YAML:
#   hive:
#     kerberos:
#       keytab: /etc/security/keytabs/svcaccount.keytab   # path sull'EDGE NODE
#       client_principal: "${HIVE_KRB_CLIENT_PRINCIPAL}"
# HIVE_KRB_CLIENT_PRINCIPAL=svcaccount@CORP.COM

# === Alert email ===
SMTP_USER=
SMTP_PASS=

# === Webhook ===
WEBHOOK_SECRET=

# =============================================================================
# Secrets via file (Docker secrets, k8s mounted secrets)
# =============================================================================
# In config YAML usa: ambari_pass: "${file:/run/secrets/ambari_pass}"
# Il file deve contenere il secret senza newline finali.

# =============================================================================
# Secrets via comando (Vault, pass, AWS Secrets Manager, Azure Key Vault)
# =============================================================================
# In config YAML usa (esempi):
#   ambari_pass: "${cmd:vault kv get -field=password secret/hadoop/ambari}"
#   ambari_pass: "${cmd:pass show hadoop/ambari}"
#   ambari_pass: "${cmd:aws secretsmanager get-secret-value --secret-id ambari --query SecretString --output text}"
#   ambari_pass: "${cmd:az keyvault secret show --vault-name myVault --name ambariPass --query value -o tsv}"
