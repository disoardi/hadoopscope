# Config con credenziali reali
# Ignora TUTTI i file .yaml in config/ — includi esplicitamente solo quelli safe
config/*.yaml
!config/example.yaml
!config/test.yaml
!config/docker-test.yaml
# File .env ovunque nell'albero
.env
config/.env
secrets.env
# Keytab Kerberos ovunque nell'albero
*.keytab
**/*.keytab

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
venv/
.venv/
poetry.lock       # non committato — il tool non ha runtime deps

# Poetry local config
poetry.toml

# HadoopScope runtime
/tmp/hadoopscope-*/
~/.hadoopscope/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Docker
.docker/

# Logs
*.log
hadoopscope-*.log
hadoopscope-*.json
